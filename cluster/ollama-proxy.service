[Unit]
Description=Ollama Cluster Proxy (port 11435)
Documentation=file:///home/bdeeley/test/cluster/README.md
After=network-online.target ollama.service
Wants=ollama.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /home/bdeeley/test/cluster/proxy.py
Restart=always
RestartSec=5
User=bdeeley
StandardOutput=journal
StandardError=journal
SyslogIdentifier=ollama-proxy

[Install]
WantedBy=default.target
