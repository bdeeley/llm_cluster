# EXO Cluster Configuration - Standardized across all nodes

# ============================================================================
# CLUSTER TOPOLOGY
# ============================================================================
CLUSTER_NAME="exo-cluster"
CLUSTER_DOMAIN="deeleymotorsports.lan"

# Master node
MASTER_HOST="maxpower"
MASTER_IP="172.16.0.28"
MASTER_API_PORT="52415"
MASTER_LIBP2P_PORT="5678"

# Local worker (on master hardware)
WORKER_HOST="maxpower-local"
WORKER_IP="127.0.0.1"
WORKER_API_PORT="52416"
WORKER_LIBP2P_PORT="5680"

# Remote nodes
# Format: name:ip:libp2p_port
# June 2026 active compute: maxpower + theplague (debian decommissioned)
REMOTE_NODES="theplague:172.16.0.29:5679"

# ============================================================================
# STANDARD PATHS (same on all nodes)
# ============================================================================
EXO_ROOT="/home/bdeeley/exo"
EXO_VENV="${EXO_ROOT}/.venv"
EXO_VENV_PYTHON="${EXO_VENV}/bin/python3"
EXO_VENV_UV="/home/bdeeley/.local/bin/uv"

# Standardized per-instance cache directories
CACHE_BASE="/home/bdeeley/.cache"
SHARE_BASE="/home/bdeeley/.local/share"

# Master
CACHE_MASTER="${CACHE_BASE}/exo-master"
SHARE_MASTER="${SHARE_BASE}/exo-master"
LOG_MASTER="${CACHE_MASTER}/exo_log"
EVENT_LOG_MASTER="${SHARE_MASTER}/event_log"

# Worker
CACHE_WORKER="${CACHE_BASE}/exo-worker"
SHARE_WORKER="${SHARE_BASE}/exo-worker"
LOG_WORKER="${CACHE_WORKER}/exo_log"
EVENT_LOG_WORKER="${SHARE_WORKER}/event_log"

# Remote (node-specific)
# These get expanded per-node with node name
CACHE_REMOTE_TEMPLATE="${CACHE_BASE}/exo-{NODE_NAME}"
SHARE_REMOTE_TEMPLATE="${SHARE_BASE}/exo-{NODE_NAME}"
LOG_REMOTE_TEMPLATE="${CACHE_BASE}/exo-{NODE_NAME}/exo_log"
EVENT_LOG_REMOTE_TEMPLATE="${SHARE_BASE}/exo-{NODE_NAME}/event_log"

# ============================================================================
# ENVIRONMENT VARIABLES
# ============================================================================
# CUDA Configuration
export CUDA_HOME="/usr"
export CUDA_PATH="/usr"
export CPATH="/usr/include"
export CPLUS_INCLUDE_PATH="/usr/include"

# HuggingFace (shared across all nodes)
export HF_HOME="/BIGMIRROR/exo-models-local"
export TRANSFORMERS_CACHE="${HF_HOME}/transformers"
# Using local cache only - no token needed
export HF_TOKEN=""

# Model cache (shared across all nodes)
export HF_HUB_CACHE="${SHARE_BASE}/huggingface/hub"

# ============================================================================
# BOOTSTRAP PEER CONFIGURATION
# Format: /ip4/{IP}/tcp/{PORT},{IP}/{PORT},...
# ============================================================================
BOOTSTRAP_PEERS="/ip4/172.16.0.28/tcp/5678,/ip4/172.16.0.28/tcp/5680,/ip4/172.16.0.29/tcp/5679"

# ============================================================================
# GPU CONFIGURATION PER NODE
# ============================================================================
# Master: both GPUs
GPU_MASTER="0,1"
OVERRIDE_MEMORY_MB_MASTER="24000"

# Worker: GPU 0 (shares with master's GPU1, but CUDA_VISIBLE_DEVICES=0 for isolation)
GPU_WORKER="0"
OVERRIDE_MEMORY_MB_WORKER="20000"

# Remote nodes: single GPU each
GPU_THEPLAGUE="0"
OVERRIDE_MEMORY_MB_REMOTE="20000"

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Verbose logging flags
EXO_LOG_LEVEL="INFO"  # DEBUG for more verbose
EXO_RUNNER_LOG_VERBOSE="1"
RUST_LOG="info"

# ============================================================================
# MLX CONFIGURATION
# ============================================================================
MLX_METAL_FAST_SYNCH="1"
EXO_FAST_SYNCH="true"

# ============================================================================
# SERVICE NAMES
# ============================================================================
SERVICE_MASTER="exo.service"
SERVICE_WORKER="exo-worker.service"
SERVICE_REMOTE="exo.service"

# ============================================================================
# VALIDATION
# ============================================================================
# Ensure all required paths exist
validate_paths() {
  local paths=(
    "$EXO_ROOT"
    "$EXO_VENV"
    "$CACHE_BASE"
    "$SHARE_BASE"
  )
  
  for path in "${paths[@]}"; do
    if [ ! -d "$path" ]; then
      echo "ERROR: Path not found: $path"
      return 1
    fi
  done
  
  return 0
}

# Verify NVIDIA library paths
validate_nvidia_libs() {
  local nvidia_libs=(
    "${EXO_VENV}/lib/python3.13/site-packages/nvidia/cublas/lib"
    "${EXO_VENV}/lib/python3.13/site-packages/nvidia/cuda_nvrtc/lib"
    "${EXO_VENV}/lib/python3.13/site-packages/nvidia/cudnn/lib"
    "${EXO_VENV}/lib/python3.13/site-packages/nvidia/cufft/lib"
    "${EXO_VENV}/lib/python3.13/site-packages/nvidia/nccl/lib"
    "${EXO_VENV}/lib/python3.13/site-packages/nvidia/nvjitlink/lib"
  )
  
  local found=0
  for lib in "${nvidia_libs[@]}"; do
    if [ -d "$lib" ]; then
      found=$((found + 1))
    fi
  done
  
  echo "Found $found/6 NVIDIA library paths"
  return $([[ $found -eq 6 ]] && echo 0 || echo 1)
}
