[Unit]
Description=Ollama LLM Inference Node
After=network-online.target llm-node-setup.service
Wants=network-online.target

[Service]
EnvironmentFile=/etc/llm-node.conf
ExecStart=/usr/local/bin/ollama serve
Restart=always
RestartSec=5
Environment="OLLAMA_HOST=0.0.0.0:11434"
Environment="OLLAMA_NUM_GPU=1"

[Install]
WantedBy=multi-user.target
